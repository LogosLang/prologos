{
  "name": "prologos",
  "displayName": "Prologos",
  "description": "Language support for Prologos — functional-logic language with dependent types, session types, and propagator networks",
  "version": "0.1.0",
  "publisher": "prologos",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:prologos"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "prologos",
        "aliases": [
          "Prologos",
          "prologos"
        ],
        "extensions": [
          ".prologos"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/prologos-light.png",
          "dark": "./icons/prologos-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "prologos",
        "scopeName": "source.prologos",
        "path": "./syntaxes/prologos.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "prologos",
        "path": "./snippets/prologos.json"
      }
    ],
    "configuration": {
      "title": "Prologos",
      "properties": {
        "prologos.racketPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Racket executable. Auto-detected if empty."
        },
        "prologos.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Prologos LSP server (server.rkt). Auto-detected if empty."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
