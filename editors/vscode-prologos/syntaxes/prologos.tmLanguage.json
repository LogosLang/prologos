{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Prologos",
  "scopeName": "source.prologos",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#char-literal" },
    { "include": "#keyword-literal" },
    { "include": "#nat-literal" },
    { "include": "#rational-literal" },
    { "include": "#approx-literal" },
    { "include": "#number" },
    { "include": "#boolean" },
    { "include": "#multiplicity" },
    { "include": "#operator" },
    { "include": "#quote-syntax" },
    { "include": "#hole" },
    { "include": "#declaration-keyword" },
    { "include": "#expression-keyword" },
    { "include": "#module-keyword" },
    { "include": "#builtin-type" },
    { "include": "#builtin-constant" },
    { "include": "#logic-variable" },
    { "include": "#qualified-name" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.semicolon.prologos",
          "match": ";.*$"
        }
      ]
    },
    "string": {
      "name": "string.quoted.double.prologos",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.prologos",
          "match": "\\\\."
        }
      ]
    },
    "char-literal": {
      "name": "constant.character.prologos",
      "match": "\\\\(?:newline|space|tab|return|backspace|nul|alarm|escape|delete|[a-zA-Z0-9]|u[0-9a-fA-F]{1,6})(?=[\\s\\[\\](){};<>]|$)"
    },
    "keyword-literal": {
      "name": "constant.other.keyword.prologos",
      "match": ":[a-zA-Z_][a-zA-Z0-9_?!'-]*",
      "comment": "Keyword literals like :foo, :bar — but NOT :refer, :as, :no-prelude etc. (those are handled as module-keyword)"
    },
    "nat-literal": {
      "name": "constant.numeric.natural.prologos",
      "match": "\\b[0-9]+N\\b"
    },
    "rational-literal": {
      "name": "constant.numeric.rational.prologos",
      "match": "\\b[0-9]+/[0-9]+\\b"
    },
    "approx-literal": {
      "name": "constant.numeric.approx.prologos",
      "match": "~[0-9]+(?:\\.[0-9]+)?(?:/[0-9]+)?"
    },
    "number": {
      "name": "constant.numeric.prologos",
      "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"
    },
    "boolean": {
      "name": "constant.language.boolean.prologos",
      "match": "\\b(?:true|false)\\b"
    },
    "multiplicity": {
      "name": "storage.modifier.multiplicity.prologos",
      "match": "(?<=\\s|\\[|\\(|^):(?:0|1|w)\\b"
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.prologos",
          "match": "->|=>|-0>|-1>|-w>"
        },
        {
          "name": "keyword.operator.pipe.prologos",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.compose.prologos",
          "match": ">>"
        },
        {
          "name": "keyword.operator.bind.prologos",
          "match": ":="
        },
        {
          "name": "keyword.operator.separator.prologos",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.wildcard.prologos",
          "match": "\\b_\\b"
        }
      ]
    },
    "quote-syntax": {
      "patterns": [
        {
          "name": "keyword.operator.quote.prologos",
          "match": "'(?=\\[)"
        },
        {
          "name": "keyword.operator.quasiquote.prologos",
          "match": "`"
        },
        {
          "name": "keyword.operator.unquote.prologos",
          "match": ","
        },
        {
          "name": "keyword.operator.dollar.prologos",
          "match": "\\$(?=[A-Z])"
        }
      ]
    },
    "hole": {
      "patterns": [
        {
          "name": "variable.other.hole.prologos",
          "match": "\\?\\?[a-zA-Z_][a-zA-Z0-9_?!'-]*"
        },
        {
          "name": "variable.other.hole.prologos",
          "match": "\\?\\?"
        }
      ]
    },
    "declaration-keyword": {
      "name": "keyword.control.declaration.prologos",
      "match": "\\b(?:defn|def|data|deftype|spec|trait|impl|bundle|property|functor|defmacro|foreign|subtype|capability|relation|clause)\\b"
    },
    "expression-keyword": {
      "name": "keyword.control.expression.prologos",
      "match": "\\b(?:match|fn|let|if|cond|do|the|forall|exists|where|when|with-transient|transient|reduce|eval|infer|check|expand|expand-1|expand-full|parse|elaborate|solve|query)\\b"
    },
    "module-keyword": {
      "name": "keyword.control.module.prologos",
      "match": "\\b(?:ns|provide|require|imports|exports)\\b"
    },
    "builtin-type": {
      "name": "support.type.prologos",
      "match": "\\b(?:Type|Pi|Sigma|Nat|Bool|Int|Rat|List|Vec|Fin|Eq|Chan|Session|Option|Result|Pair|String|Char|Symbol|Datum|Keyword|Set|Map|PVec|LSeq|Nil|Posit8|Posit16|Posit32|Posit64|Quire8|Quire16|Quire32|Quire64|TVec|TMap|TSet)\\b"
    },
    "builtin-constant": {
      "name": "constant.language.prologos",
      "match": "\\b(?:zero|refl|nil|cons|nothing|just|pair|ok|err|inc|suc|vnil|vcons|fzero|fsuc)\\b"
    },
    "logic-variable": {
      "name": "variable.other.logic.prologos",
      "match": "\\?[a-zA-Z_][a-zA-Z0-9_?!'-]*"
    },
    "qualified-name": {
      "patterns": [
        {
          "name": "entity.name.namespace.prologos",
          "match": "[a-zA-Z_][a-zA-Z0-9_-]*(?:\\.[a-zA-Z_][a-zA-Z0-9_-]*)+(?=::)"
        },
        {
          "name": "punctuation.separator.namespace.prologos",
          "match": "::"
        }
      ]
    },
    "identifier": {
      "name": "variable.other.prologos",
      "match": "[a-zA-Z_][a-zA-Z0-9_?!'-]*"
    }
  }
}
