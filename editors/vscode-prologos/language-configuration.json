{
  "comments": {
    "lineComment": ";"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'[", "close": "]" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(defn|def|data|deftype|match|fn|impl|trait|bundle|if|let|do|ns|spec|property|functor|foreign|where|cond)\\b",
    "decreaseIndentPattern": "^\\s*[\\]\\)\\}]"
  },
  "wordPattern": "[a-zA-Z_?!][a-zA-Z0-9_?!'-]*",
  "onEnterRules": [
    {
      "beforeText": "^\\s*(defn|def|data|deftype|match|fn|impl|trait|spec|property|functor|foreign|where)\\b.*$",
      "action": { "indent": "indent" }
    }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(defn|def|data|deftype|impl|trait|bundle|spec|property|functor|foreign|ns)\\b",
      "end": "^\\s*$"
    }
  }
}
