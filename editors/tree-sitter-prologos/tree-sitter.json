    "authors": [
      {
        "name": "Prologos Contributors"
      }
    ],
    "links": {
      "repository": "https://github.com/prologos-lang/tree-sitter-prologos"
    }
  },
  "bindings": {
    "c": true,
    "node": true
  }
}
