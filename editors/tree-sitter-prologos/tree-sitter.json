      "scope": "source.prologos",
      "path": ".",
      "file-types": [
        "prologos"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "prologos"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
