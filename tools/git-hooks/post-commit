#!/usr/bin/env bash
#
# post-commit — background mempalace re-mine when docs changed
#
# Triggers a silent, backgrounded `mempalace mine ./docs --wing prologos`
# when the just-completed commit touched `docs/tracking/**` or
# `docs/research/**`. Commit returns immediately; mine runs in the
# background and logs to /var/tmp/mempalace-auto-mine.log.
#
# Landed as PPN-4C mempalace Phase 3 (2026-04-23). Previously deferred
# in .claude/rules/mempalace.md § Re-mine cadence.
#
# Design:
# - Git hook, NOT a Claude Code hook. No prompt-injection path.
# - Fast-path exits silently if no doc changes, mempalace missing, or
#   palace not initialized — safe on any dev machine.
# - Content-hash dedup in mempalace makes re-mines incremental.
# - Log file preserves history for debugging freshness issues.

set -e

# Resolve repo root (hook runs from .git/hooks/ — cd to root for doc paths)
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$REPO_ROOT"

# Did this commit touch docs/tracking/** or docs/research/**?
CHANGED="$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null \
  | grep -E '^docs/(tracking|research)/' || true)"

if [ -z "$CHANGED" ]; then
  # Not a doc-relevant commit — exit silently, fast path
  exit 0
fi

# Skip silently if mempalace not installed on this machine
command -v mempalace >/dev/null 2>&1 || exit 0

# Skip silently if palace not initialized (init has not been run)
[ -d "$HOME/.mempalace/palace" ] || exit 0

LOG="/var/tmp/mempalace-auto-mine.log"
LOCK_FILE="/var/tmp/mempalace-auto-mine.lock"

# Concurrency guard — skip if another mine is already running.
# Without this, rapid doc commits spawn overlapping mines that compete
# for chroma.sqlite3 + leave stale lockfiles behind on crash.
# Diagnosed 2026-04-26: 426 stale locks accumulated, palace state corrupted.
if [ -f "$LOCK_FILE" ]; then
  RUNNING_PID="$(cat "$LOCK_FILE" 2>/dev/null || true)"
  if [ -n "$RUNNING_PID" ] && kill -0 "$RUNNING_PID" 2>/dev/null; then
    {
      printf '=== %s post-commit SKIP — mine already running (pid %s) ===\n\n' \
        "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        "$RUNNING_PID"
    } >>"$LOG" 2>&1
    exit 0
  fi
  # Stale lockfile (owning process is dead) — clean up before proceeding.
  rm -f "$LOCK_FILE"
fi

# Background mine; disown so the commit completes immediately.
# The subshell:
# - writes its own PID to the lockfile FIRST (close race window with
#   any concurrent commit that fires before this point)
# - removes the lockfile on EXIT/INT/TERM (releases lock cleanly even
#   on signal)
# - sets OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES to work around macOS
#   fork()/CoreFoundation incompatibility with Python multiprocessing
#   ("The process has forked and you cannot use this CoreFoundation
#   functionality safely. You MUST exec()."). Without this, every mine
#   crashes on Darwin, leaving stale locks. See
#   https://bugs.python.org/issue33725
(
  echo "$BASHPID" > "$LOCK_FILE" 2>/dev/null || echo $$ > "$LOCK_FILE"
  trap 'rm -f "$LOCK_FILE"' EXIT INT TERM

  export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

  printf '=== %s post-commit re-mine (HEAD=%s) ===\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    "$(git rev-parse HEAD)"
  printf 'Triggering paths (first 10):\n'
  printf '%s\n' "$CHANGED" | head -10 | sed 's/^/  /'
  printf '\n'
  mempalace mine ./docs --wing prologos
  printf '=== done at %s ===\n\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
) >>"$LOG" 2>&1 &

# disown may not exist in sh; guard silently
disown 2>/dev/null || true

exit 0
