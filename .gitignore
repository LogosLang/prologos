outside/


# Generated benchmark report
racket/prologos/data/benchmarks/report.html

# Per-run benchmark summary (regenerated by run-affected-tests.rkt; churns every PR)
racket/prologos/data/benchmarks/last-run-summary.txt

# Per-machine append-only test timing history. Each test run appends one
# JSON line. Tracking caused intermittent clobbering via stash/checkout/
# merge interactions and bloated repo size (90+MB). Local-state file,
# not a shared baseline. Used by tools/benchmark-tests.rkt for trend
# analysis on the local machine.
racket/prologos/data/benchmarks/timings.jsonl

# Per-run failure logs from run-affected-tests.rkt. Regenerated every
# test run (overwriting prior content). Diagnostic value is limited to
# the most recent run; tracking just adds churn.
racket/prologos/data/benchmarks/failures/*.log

# Tangled stdlib output (generated from book chapters)
.tangled/

# Woven stdlib HTML (generated from book chapters)
docs/stdlib-book/racket/prologos/data/cache/
racket/prologos/data/cache/

