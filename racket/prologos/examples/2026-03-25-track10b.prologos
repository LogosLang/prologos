def i2 := [int* 6 7]                  ;; 42
def i3 := [int- 10 20]                ;; -10

;; Generic arithmetic across types
def g1 := [+ 3 4]                     ;; 7 : Int
def g2 := [- 10 3]                    ;; 7 : Int

