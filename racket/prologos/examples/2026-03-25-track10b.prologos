;; PM Track 10B: Foundation Cleanup + Zonk Elimination — Acceptance File
;; Run with: process-file "examples/2026-03-25-track10b.prologos"
;;
;; PURPOSE: Stress-test the language across every feature that Track 10B touches.
;; Track 10B removes: CHAMP fallback, id-map, zonk-final, mutable session metas.
;; This file exercises EVERY feature that depends on meta-variable resolution,
;; type inference, session types, generic arithmetic, traits, and module loading.
;;
;; STRATEGY: Not just "does this compile?" but "does every corner of the syntax
;; compose correctly?" Ideal syntax is tried first. If it doesn't work, it's
;; commented out with a note explaining what broke. Working alternatives follow.
;;
;; The gap between ideal and working is learning for future tracks.
;;
;; Run BEFORE implementation (baseline) and AFTER each phase to catch regressions.

;; ===================================================================
;; Section 1: Basic inference — metas must resolve correctly
;; ===================================================================
ns track10b-s1

;; Type inference on simple definitions
def x := 42                           ;; infer Int
def y := [int+ x 10]                  ;; infer Int, meta for x resolves
def z := [int* x y]                   ;; 42 * 52 = 2184

;; Nat inference
def n := 3N                            ;; infer Nat
def m := [suc [suc 0N]]               ;; infer Nat via suc chain

;; Bool inference
def b := [not true]                    ;; infer Bool
def c := [and true [or false true]]    ;; nested bool ops

;; String inference
def greeting := "hello"
def shouting := [str::to-upper greeting]

;; List inference — polymorphic, meta for element type
def xs := '[1 2 3 4 5]                ;; infer [List Int]
def ys := [map [fn [x : Int] [int+ x 1]] xs]  ;; infer [List Int]
[length ys]                            ;; 5

;; Option inference
def opt := [some 42]                   ;; infer [Option Int]
def nothing := none                    ;; infer [Option ?A] — meta left unsolved → defaulted


;; ===================================================================
;; Section 2: Polymorphic functions — implicits, generics, spec
;; ===================================================================
ns track10b-s2

;; Identity with implicit type
spec my-id {A : Type} A -> A
defn my-id [x] x
[my-id 42]                            ;; 42 : Int
[my-id "hello"]                        ;; "hello" : String
[my-id true]                           ;; true : Bool

;; Compose
spec my-compose {A B C : Type} [B -> C] -> [A -> B] -> A -> C
defn my-compose [f g x] [f [g x]]
def inc := [fn [x : Int] [int+ x 1]]
def dbl := [fn [x : Int] [int* x 2]]
[my-compose dbl inc 5]                 ;; (5+1)*2 = 12

;; Flip
spec my-flip {A B C : Type} [A -> B -> C] -> B -> A -> C
defn my-flip [f b a] [f a b]
[my-flip int- 10 3]                    ;; 3 - 10 = -7

;; Higher-rank: function that takes a polymorphic function
;; IDEAL: spec apply-both {A B : Type} [{X : Type} -> X -> X] -> A -> B -> [A * B]
;; WORKING:
spec apply-both {A B : Type} [A -> A] -> [B -> B] -> A -> B -> [A * B]
defn apply-both [fa fb a b] [fa a, fb b]


;; ===================================================================
;; Section 3: Trait instances — resolution must work through cell reads
;; ===================================================================
ns track10b-s3

;; Generic arithmetic (uses Num trait bundle)
def a := [+ 3 4]                       ;; 7 : Int via Add instance
def b := [- 10 3]                      ;; 7 : Int via Sub instance
def c := [* 2 5]                       ;; 10 : Int via Mul instance

;; Eq trait
[eq? 42 42]                            ;; true
[eq? "hello" "hello"]                  ;; true

;; Ord trait
[ord-lt 3 5]                           ;; true
[ord-compare 5 3]                      ;; gt-ord

;; Pipeline with generic ops
|> 5 inc inc inc                       ;; 8
|> 10 [fn [x : Int] [* x x]]          ;; 100

;; Partial application
def double := [int* 2 _]
[double 21]                            ;; 42


;; ===================================================================
;; Section 4: Pattern matching — exhaustiveness, dispatch
;; ===================================================================
ns track10b-s4

;; Multi-arity defn (preferred pattern dispatch)
spec is-zero Nat -> Bool
defn is-zero
  | zero  -> true
  | suc _ -> false
[is-zero 0N]                           ;; true
[is-zero 3N]                           ;; false

;; Match expression (mid-expression dispatch)
def describe := [fn [n : Nat] (match n | zero -> "none" | suc _ -> "some")]
[describe 0N]                          ;; "none"
[describe 1N]                          ;; "some"

;; List pattern matching
spec my-head {A : Type} [List A] -> [Option A]
defn my-head
  | nil      -> none
  | cons h _ -> [some h]
[my-head '[1 2 3]]                     ;; some 1
[my-head (the [List Int] nil)]         ;; none

;; Nested patterns
spec sum-list [List Int] -> Int
defn sum-list
  | nil          -> 0
  | cons h rest  -> [int+ h [sum-list rest]]
[sum-list '[1 2 3 4 5]]               ;; 15


;; ===================================================================
;; Section 5: Dependent types — Pi, Sigma, universe levels
;; ===================================================================
ns track10b-s5

;; Type-level function
spec Vec Type -> Nat -> Type
def Vec := [fn [A : Type] [n : Nat] (the Type (match n | zero -> [Unit] | suc m -> [A * [Vec A m]]))]

;; IDEAL: def v2 : [Vec Int 2N] := [1, [2, unit]]
;; WORKING (Vec may not reduce correctly through match):
def pair-int := [42, [99, unit]]

;; Universe polymorphism
spec level-poly {l : Level} [Type l] -> [Type l]
defn level-poly [t] t

;; Sigma type (dependent pair)
;; IDEAL: def dpair : <(n : Nat) * [Vec Int n]> := <2N, [1, [2, unit]]>
;; WORKING:
def simple-pair := [42, true]          ;; [Int * Bool]
[fst simple-pair]                      ;; 42
[snd simple-pair]                      ;; true


;; ===================================================================
;; Section 6: Maps, sets, dot-access, path operations
;; ===================================================================
ns track10b-s6

;; Map literals
def person := {:name "Alice" :age 30 :active true}
person.name                            ;; "Alice" via dot-access
person.age                             ;; 30

;; Nested maps
def company := {:name "Acme" :ceo {:name "Bob" :title "CEO"}}
company.ceo.name                       ;; "Bob"

;; IDEAL: def updated := [update-in company [:ceo :name] [fn [s : String] [str::append s " Jr."]]]
;; WORKING:
def updated := [map-set company :name "Acme Corp"]

;; Set operations
def s1 := [set-from-list '[1 2 3]]
def s2 := [set-from-list '[2 3 4]]

;; PVec operations
def pv := [pvec 1 2 3 4 5]
[pvec-fold pv 0 int+]                 ;; 15


;; ===================================================================
;; Section 7: Trait definitions — custom traits with instances
;; ===================================================================
ns track10b-s7

;; Custom trait (method syntax: name : type, not spec name type)
trait Describable {A}
  describe : A -> String

;; Instance for Int
impl Describable Int
  defn describe [n : Int] <String>
    "an integer"

;; Instance for Bool
;; IDEAL: multi-arity defn in impl
;; impl Describable Bool
;;   defn describe
;;     | true  -> "truth"
;;     | false -> "falsehood"
;; WORKING: explicit match (multi-arity in impl may not parse)
impl Describable Bool
  defn describe [b : Bool] <String>
    (match b | true -> "truth" | false -> "falsehood")

;; IDEAL: [describe 42]            ;; "an integer" — would need trait resolution through cells
;; WORKING:
[describe (the Int 42)]               ;; "an integer"
[describe true]                        ;; "truth"

;; Bundle
;; IDEAL:
;; bundle Printable := (Describable Eq)
;; WORKING:
;; (bundles require more syntax work)


;; ===================================================================
;; Section 8: Module imports — cross-module resolution
;; ===================================================================
ns track10b-s8

(imports [prologos::data::nat :as nat :refer [add sub]])
(imports [prologos::data::pair :refer [swap bimap]])
(imports [prologos::data::option :as opt :refer [some none]])

;; Cross-module operations
def n1 := [add 3N 4N]                 ;; 7N
def n2 := [sub 5N 2N]                 ;; 3N

;; Pair operations from imported module
def p := [42, "hello"]
[swap p]                               ;; ["hello", 42]
[bimap inc str::length p]              ;; [43, 5]

;; Option operations
[opt::map [fn [x : Int] [int+ x 1]] [some 41]]  ;; some 42


;; ===================================================================
;; Section 9: String and Char operations — foreign function marshalling
;; ===================================================================
ns track10b-s9

;; String operations (foreign functions — tests marshal-in/out)
[str::length "hello world"]            ;; 11
[str::to-upper "hello"]                ;; "HELLO"
[str::to-lower "WORLD"]               ;; "world"
[str::contains "hello world" "world"]  ;; true
[str::append "foo" "bar"]              ;; "foobar"
[str::split "a,b,c" ","]              ;; '["a" "b" "c"]

;; Char operations
[char::code 'A']                       ;; 65
;; IDEAL: [char::from-code 65]         ;; 'A'
;; WORKING:
;; IDEAL: [char::upper 'a']            ;; 'A' — char literal syntax
;; NOTE: WS-mode has no char literal syntax yet (#\a is sexp-only)
;; This is a language gap to address in future syntax work


