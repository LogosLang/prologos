;; ===================================================================
;; Section 11: Control flow — if, cond, when, do, let
;; ===================================================================
ns track10b-s11

;; If expression (prefer pattern matching, but test it works)
(if true 1 2)                          ;; 1

;; Cond (desugars to nested if)
;; IDEAL:
;; cond
;;   [eq? 1 1] -> "equal"
;;   [eq? 1 2] -> "nope"
;;   else      -> "fallback"
;; NOTE: cond WS syntax needs investigation — commented out for now
;; WORKING: use nested if
(if [eq? 1 1] "equal" (if [eq? 1 2] "nope" "fallback"))

;; When (defmacro from prelude)
(when true "yes")                      ;; "yes" — tests preparse macro restoration from .pnet

;; Let binding
;; IDEAL: (let [x 10] [y 20] [int+ x y])
;; NOTE: let syntax may use different binding form
;; WORKING: use def instead
def let-x : Int := 10
def let-y : Int := 20
[int+ let-x let-y]                     ;; 30

;; Do block
;; IDEAL:
;; do
;;   x : Int = 42
;;   y : Int = [int+ x 1]
;;   y
;; NOTE: do block binding syntax is [name : type = value], not (def ...)
;; WORKING: use sequential defs
def do-x : Int := 42
def do-y : Int := [int+ do-x 1]
do-y                                    ;; 43


