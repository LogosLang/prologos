;; ===================================================================
;; Section 18: Varargs and list literals
;; ===================================================================
ns track10b-s18

;; List literals
def nums := '[10 20 30 40 50]
[head nums]                            ;; some 10
[tail nums]                            ;; '[20 30 40 50]
[length nums]                          ;; 5

;; Heterogeneous operations (should all work on List Int)
[reverse nums]                         ;; '[50 40 30 20 10]
[append '[1 2] '[3 4]]                 ;; '[1 2 3 4]
;; IDEAL: [filter [fn [x : Int] [int> x 25]] nums]
;; NOTE: `int>` has `>` which the WS reader parses as angle bracket
;; WORKING: use ord-gt instead
[filter [fn [x : Int] [ord-gt x 25]] nums]  ;; '[30 40 50]

;; Int comparison helpers
