;; ===================================================================
;; Section 25: Comprehensive composition test
;; ===================================================================
ns track10b-s25

;; This section composes MANY features together to stress-test
;; the pipeline end-to-end after Track 10B changes.

;; Polymorphic function + trait constraint + list ops + pipeline
;; IDEAL:
;; spec process-and-sort {A : Type} [List A] -> [A -> Int] -> [List Int]
;;   :where (Ord A)
;; defn process-and-sort [xs f]
;;   |> xs [map f] sort
;; NOTE: :where on user specs crashes — see Section 19

;; WORKING: concrete type (no generic)
spec process-and-sort [List Int] -> [Int -> Int] -> [List Int]
defn process-and-sort [xs f]
  |> xs [map f] sort

[process-and-sort '[3 1 4 1 5] [fn [x : Int] [int* x x]]]
;; sort [map square '[3 1 4 1 5]] = sort '[9 1 16 1 25] = '[1 1 9 16 25]

;; Nested module access + generic ops + let + pattern match
;; IDEAL: (let [data {:x 10}] data.x)
;; WORKING: use def
def comp-data := {:x 10 :y 20 :z 30}
comp-data.x                            ;; 10
