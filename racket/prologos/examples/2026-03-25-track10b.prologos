|> 5 inc inc inc                       ;; 8
|> '[1 2 3 4 5] [map [fn [x : Int] [int* x x]]] [foldr int+ 0]

;; IDEAL: |> "hello" str::to-upper str::length  ;; 5
;; WORKING:
|> "hello" str::to-upper

