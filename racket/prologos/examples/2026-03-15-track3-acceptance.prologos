;; ========================================================================
;; SECTION Z: UNCOMMENTED BASELINE — Must Pass Today
;; ========================================================================
;;
;; All uncommented expressions from above, plus regression-critical
;; operations. If ANY fail after a Track 3 phase, it's a regression.

;; Nat arithmetic (A4)
add [suc [suc [suc zero]]] [suc [suc zero]]
mult [suc [suc zero]] [suc [suc [suc zero]]]

;; Polymorphic id (B1)
my-id "track 3 acceptance"

;; Boolean logic (A2)
my-and [my-not false] [my-or false true]

;; Eq/Ord via prelude dicts (C1/C2)
