;; map (fn [x : Nat] suc x) nums
;; filter is-zero nums
;; foldr (fn [x : Nat] (fn [acc : Nat] [add x acc])) zero nums
;; => Expected: [2N 3N 4N], [], 6N

;; --- D2: List literal syntax ---
;; BUG: '[1 2 3] produces a Datum (quoted s-expression), not List Int.
;;
;; def ints : [List Int] := '[1 2 3 4 5]
;; length ints
;; => Expected: 5N : Nat

;; --- D3: Option ---

def opt-some : [Option Nat] := some [suc zero]
def opt-none : [Option Nat] := none

;; --- D4: Result ---

def ok-val : [Result Nat String] := ok [suc zero]
def err-val : [Result Nat String] := err "oops"

;; --- D5: Pair (Sigma) ---
;; BUG (L3): [A * B] Sigma syntax doesn't resolve at file-level defs.
;; `*` is unbound as a type operator.
;;
;; def p : [Nat * Bool] := pair zero true
;; fst p
;; snd p
;; => Expected: 0N, true

