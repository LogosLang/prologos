;; ========================================================================
;;
;;   Track 3 Acceptance File — Cell-Primary Registries
;;
;;   STATUS: Phase 0 (Pre-Implementation Baseline)
;;   Run via: process-file "racket/prologos/examples/2026-03-15-track3-acceptance.prologos"
;;
;;   Track 3 is an infrastructure track (no syntax changes). This file
;;   broadly exercises Prologos features in ideal WS syntax to confirm
;;   no regressions from the cell-primary migration. Expressions that
;;   don't work are commented out with annotations explaining WHY.
;;   These are pre-existing L3 gaps to address — NOT Track 3 regressions.
;;
;;   Conventions:
;;     - Uncurried type signatures: `spec f A B -> C`
;;     - Direct pattern dispatch on defn: `defn f | [pat] -> body`
;;     - match for multi-step logic within a single clause
;;     - Full prelude (no :no-prelude) — exercise the standard library
;;     - Commented-out = aspirational ideal; annotated with BUG/BLOCKED
;;     - Uncommented = must pass today; regression if broken
;;
;;   Sections:
;;     A. Pattern matching and basic definitions
;;     B. Polymorphic functions and implicit arguments
;;     C. Traits and instances (Eq, Ord, Add, etc.)
;;     D. Collections (List, Option, Result, Pair, Set, Map)
;;     E. Higher-order functions (map, filter, fold, pipe, compose)
;;     F. Data type definitions and constructors
;;     G. Dependent types (Vec, Fin)
;;     H. Numeric operations (Int, Rat, Posit)
;;     I. String and Char operations
;;     J. Dot-access and Map syntax
;;     K. Module imports and qualified access
;;     L. Where-clause generics and specialize
;;     M. Bundle and first-class arithmetic
;;
;; ========================================================================


ns acceptance::track3


;; ========================================================================
;; SECTION A: PATTERN MATCHING AND BASIC DEFINITIONS
;; ========================================================================
;;
;; Exercises: spec/defn, direct pattern dispatch, match, Bool/Nat, if.

;; --- A1: Direct pattern dispatch on defn ---
;; BUG (L3): defn with | dispatch at file level produces match-fail holes
;; for non-first cases. The multi-clause pipe syntax is parsed but pattern
;; branches after the first don't bind correctly. This is the IDEAL syntax
;; per the grammar (see grammar.md § "Function Definition (defn)").
;;
;; spec is-zero Nat -> Bool
;; defn is-zero
;;   | [zero]  -> true
;;   | [suc _] -> false
;;
;; is-zero zero
;; is-zero [suc zero]
;; => Expected: true : Bool, false : Bool

;; --- A1-fallback: match-based (works today) ---

spec zero? Nat -> Bool
defn zero? [n]
  | zero  -> true
  | suc _ -> false

zero? 0N
zero? 1N
zero? 2N

;; --- A2: Boolean combinators ---
;; Ideal form (direct dispatch):

spec my-not Bool -> Bool
defn my-not
  | true  -> false
  | false -> true

my-not true
my-not false

spec my-and Bool Bool -> Bool
defn my-and [a b]
  | true  b  -> b
  | false _  -> false

my-and true true
my-and true false


spec my-or Bool Bool -> Bool
defn my-or [a b]
    | true  _  -> true
    | false b  -> b

my-or false true
my-or true true

spec my-xor Bool Bool -> Bool
defn my-xor [a b]
  | true  b  -> my-not b
  | false b  -> b

my-xor true false
my-xor true true
my-xor false true
my-xor false false


;; --- A3: If-then-else ---

if true 1 0
if false "yes" "no"

;; --- A4: Nat arithmetic ---
;; Ideal form (direct dispatch):
;;
;; spec add Nat Nat -> Nat
;; defn add
;;   | [x zero]    -> x
;;   | [x (suc k)] -> suc [add x k]
;;
;; spec fact Nat -> Nat
;; defn fact
;;   | [zero]  -> suc zero
;;   | [suc n] -> mult [suc n] [fact n]

;; A4-fallback:

spec add Nat Nat -> Nat
defn add [x y]
  match y
    | zero  -> x
    | suc k -> suc [add x k]

spec mult Nat Nat -> Nat
defn mult [x y]
  match y
    | zero  -> zero
    | suc k -> add x [mult x k]

spec double Nat -> Nat
defn double [x] [add x x]

add [suc zero] [suc [suc zero]]
add zero zero
mult [suc [suc zero]] [suc [suc [suc zero]]]
double [suc [suc zero]]

;; --- A5: Nested patterns ---
;; Ideal form:
;; Ideally, we should be able to match nested patterns directly in the defn clauses.

;; spec depth Nat -> Nat
;; defn depth [n]
;;   | 0N          -> zero
;;   | suc 0N      -> suc zero
;;   | suc [suc k] -> suc [suc [depth k]]

;; depth zero
;; depth [suc zero]
;; depth [suc [suc [suc zero]]]


;; ========================================================================
;; SECTION B: POLYMORPHIC FUNCTIONS AND IMPLICIT ARGUMENTS
;; ========================================================================
;;
;; Exercises: implicit erased binders {A : Type}, polymorphic application,
;; uncurried signatures.

spec my-id A -> A
  :implicits [A]
defn my-id [a] a

spec my-const A B -> A
  :implicits [A B]
defn my-const [a _] a

my-id zero
my-id true
my-id "hello"
my-id 42
my-const "hello" zero
my-const true 42

;; --- B2: Higher-order polymorphic functions ---
;; BUG (L3): Uncurried multi-arg functions whose body applies a function
;; argument (`f x`) fail at file level: the elaborator treats `f` as the
;; return value instead of applying it to `x`. The type becomes
;; `[A -> B]` instead of `B`.
;;
spec apply [A -> B] A -> [A -> B]
  :implicits [A B]
defn apply [f x] f x

;; Cannot infer type errors:
;; apply my-id 5

spec twice [A -> A] A -> [A -> A]
  :implicits [A]
defn twice [f x] 
  f [f x]

spec double Int -> Int
defn double [x] 
  [int* x 2]

spec triple Int -> Int
defn triple [x] 
  [int+ x [int* x 2]]

double 3
;; => 6 : Int
twice double 3
;; => 12 : Int

triple 5
;; => 15 : Int
twice triple 5
;; => 45 : Int


spec compose [B -> C] [A -> B] A -> C
  :implicits [A B C]
defn compose [f g x] 
  f [g x]


triple 4
;; => 12 : Int
compose double triple 4
;; => 24 : Int


;; ========================================================================
;; SECTION C: TRAITS AND INSTANCES (PRELUDE)
;; ========================================================================
;;
;; Exercises: trait resolution, dict-passing, prelude Eq/Ord instances.

;; --- C1: Eq via prelude dict (nat-eq) ---

eq-check nat-eq 2N 2N
eq-check nat-eq 0N 1N
eq-neq nat-eq   0N 1N

;; --- C2: Ord via prelude dict (nat-ord) ---

ord-compare nat-ord 1N 2N
ord-compare nat-ord 1N 1N
ord-lt nat-ord 0N 1N
ord-gt nat-ord 2N 0N

;; --- C3: Where-clause generics ---
;; BUG (L3): where-clause functions define correctly but at call site,
;; trait resolution fails: "No instance of Eq for D". The where-clause
;; dict injection doesn't wire the concrete type's dict.
;;
;; spec my-equal {A : Type} A A -> Bool where (Eq A)
;; defn my-equal [x y] where (Eq A)
;;   eq-check x y
;;
;; my-equal [suc zero] [suc zero]
;; my-equal 5 5
;; => Expected: true : Bool, true : Bool

;; --- C4: Derived comparison ---
;; BLOCKED on C3 (where-clause resolution).
;;
;; spec max-of {A : Type} A A -> A where (Ord A)
;; defn max-of [x y] where (Ord A)
;;   match [ord-compare x y]
;;     | lt-ord -> y
;;     | _      -> x
;;
;; max-of [suc [suc zero]] [suc zero]
;; => Expected: 2N : Nat

;; --- C5: Add/Sub via prelude dicts ---
;;
;; plus Nat--Add--dict [suc zero] [suc [suc zero]]
;; minus Nat--Sub--dict [suc [suc [suc zero]]] [suc zero]
;; => Expected: 3N : Nat, 2N : Nat


;; ========================================================================
;; SECTION D: COLLECTIONS (LIST, OPTION, RESULT, PAIR, SET, MAP)
;; ========================================================================
;;
;; Exercises: prelude List/Option/Result, Sigma pairs, Set/Map keywords.

;; --- D1: List construction and operations ---

def nums : [List Nat]
  cons [suc zero] [cons [suc [suc zero]] [cons [suc [suc [suc zero]]] nil]]

length nums

;; BUG (L3): head from prologos::core::collections requires HKT Foldable
;; trait resolution, which fails at L3. Dict-passing version untested.
;; head zero nums

;; D1a: map/filter over list (BLOCKED on E1: fn at L3)
