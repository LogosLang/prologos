;; ========================================================================
;; SECTION I: STRING AND CHAR OPERATIONS
;; ========================================================================
;;
;; Exercises: String/Char literals, qualified access to char::/str:: ops.

;; --- I1: String literals and qualified operations ---

def greeting : String := "hello world"
greeting
str::length greeting
str::append "hello " "world"

;; --- I2: Char literals ---
;; BUG (L3): Char literal 'a' is read as (quote a) = datum-sym, not Char.
;; WS-mode single-quote invokes quoting. Need distinct char literal syntax.
;;
;; def ch : Char := 'a'
;; char::code ch
;; char::alpha? ch
;; char::upper ch
;; => Expected: 97, true, 'A'

;; --- I3: String equality and comparison ---
;;
;; eq-check String--Eq--dict "hello" "hello"
;; eq-check String--Eq--dict "hello" "world"
;; => Expected: true, false

;; --- I4: String concatenation via Add trait ---
;;
;; plus String--Add--dict "hello " "world"
;; => Expected: "hello world" : String

;; --- I5: String operations (qualified) ---
;;
;; str-ops::split "a,b,c" ","
;; str-ops::join ", " '[1 2 3]
;; str-ops::trim "  hello  "
;; => Expected: list of strings, joined string, "hello"


