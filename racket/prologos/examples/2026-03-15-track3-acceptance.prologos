;; set-size s
;; => Expected: true, 2N

;; --- D7: Map operations ---
;;
;; def m := map-insert [map-insert [map-empty Keyword Int] :x 1] :y 2
;; map-get m :x
;; map-size m
;; => Expected: 1, 2N


;; ========================================================================
;; SECTION E: HIGHER-ORDER FUNCTIONS
;; ========================================================================
;;
;; Exercises: fn expressions, pipe (|>), compose (>>).

;; --- E1: Anonymous functions (fn) ---
;; BUG (L3): fn with typed binders fails at file level. Error: "fn: all
;; parameters except body must be bare symbols or a binder (x : T)".
;; Works at L2 (process-string-ws) but fails at L3 (process-file).
;; Root cause: file-level preparse handles fn differently from string-mode.
;;
;; (fn [x : Nat] suc x) zero
;; (fn [x : Bool] my-not x) true
;; (fn [a : Nat b : Nat] add a b) [suc zero] [suc [suc zero]]
;; => Expected: 1N, false, 3N

;; --- E2: Pipe operator (|>) ---
;;
;; zero |> suc |> suc |> suc
;; => Expected: 3N : Nat
;;
;; 5 |> (fn [x : Int] [int+ x 1]) |> (fn [x : Int] [int* x 2])
;; => Expected: 12 : Int

;; --- E3: Compose operator (>>) ---
;;
;; [suc >> suc >> suc] zero
;; => Expected: 3N : Nat

;; --- E4: Map/filter/fold with function names ---
;; If map accepts a bare function name (not just lambdas):
;;
;; map suc nums
;; map double nums
;; => Expected: [2N 3N 4N], [2N 4N 6N]


;; ========================================================================
;; SECTION F: DATA TYPE DEFINITIONS AND CONSTRUCTORS
;; ========================================================================
;;
;; Exercises: data declarations, constructor scoping, user-defined types.

;; --- F1: Simple enum ---
;; BUG (L3): data at file level creates the type but constructors are
;; UNSCOPED — not brought into the file-level namespace. The type is
;; registered but constructors aren't in the lexical environment.
;; This affects ALL data declarations in .prologos files.
;;
;; data Color where
;;   | red   : Color
;;   | green : Color
;;   | blue  : Color
;;
;; spec color-name Color -> String
;; defn color-name
;;   | [red]   -> "red"
;;   | [green] -> "green"
;;   | [blue]  -> "blue"
;;
;; color-name red
;; color-name blue
;; => Expected: "red", "blue"

;; --- F2: Parameterized recursive type ---
;;
;; data Tree [A : Type] where
;;   | leaf : A -> [Tree A]
;;   | node : [Tree A] -> [Tree A] -> [Tree A]
;;
;; spec tree-size {A : Type} [Tree A] -> Nat
;; defn tree-size [t]
;;   match t
;;     | leaf _   -> suc zero
;;     | node l r -> suc [add [tree-size l] [tree-size r]]
;;
;; def my-tree : [Tree Nat]
;;   node [node [leaf [suc zero]] [leaf [suc [suc zero]]]] [leaf [suc [suc [suc zero]]]]
;;
;; tree-size my-tree
;; => Expected: 3N

;; --- F3: Either ---
;;
;; data Either [A : Type] [B : Type] where
;;   | left  : A -> [Either A B]
;;   | right : B -> [Either A B]
;;
;; spec from-either {A B C : Type} [A -> C] [B -> C] [Either A B] -> C
;; defn from-either [f g e]
;;   match e
;;     | left a  -> f a
;;     | right b -> g b

;; --- F4: data with uncurried syntax (no `where`) ---
;;
;; data Option2 {A}
;;   none2
;;   some2 : A
;;
;; spec unwrap {A : Type} A [Option2 A] -> A
;; defn unwrap [default opt]
;;   match opt
;;     | none2   -> default
;;     | some2 x -> x
;;
;; unwrap 0 [some2 42]
;; unwrap 0 none2
;; => Expected: 42, 0


