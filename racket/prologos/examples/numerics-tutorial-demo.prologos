;; ========================================================================
;; 🌀 PASS 9 — Putting It All Together
;; ========================================================================
;;
;; Let's combine everything in more complex examples.

;; --- Pythagorean check with Rat ---
;; Does a² + b² = c²?

spec pythagorean? Int -> Int -> Int -> Bool
defn pythagorean? [a b c]
  [int-eq [int+ [int* a a] [int* b b]] [int* c c]]

[pythagorean? 3 4 5]
;; => true : Bool

[pythagorean? 5 12 13]
;; => true : Bool

[pythagorean? 3 4 6]
;; => false : Bool


;; --- Golden ratio via Fibonacci ratios ---

spec golden-approx Int -> Rat
defn golden-approx [n]
  [rat/ [from-int [fib [int+ n 1]]] [from-int [fib n]]]

;; The ratio fib(n+1)/fib(n) → φ as n grows:
[golden-approx 5]
;; => 8/5 : Rat  (= 1.6)

[golden-approx 8]
;; => 34/21 : Rat  (≈ 1.619... approaching φ = 1.6180339...)

[golden-approx 15]
;; => 987/610 : Rat  (≈ 1.618032... very close to φ!)


;; --- Posit round-trip fidelity check ---
;; Which simple fractions survive a Posit8 round-trip?

spec p8-roundtrip-exact? Rat -> Bool
defn p8-roundtrip-exact? [r]
  [rat-eq r [p8-to-rat [p8-from-rat r]]]

;; Powers of 2 are always exact:
[p8-roundtrip-exact? 1/2]
;; => true : Bool

[p8-roundtrip-exact? 1/4]
;; => true : Bool

;; Non-powers-of-2 may not be:
[p8-roundtrip-exact? 1/3]
;; => false : Bool

[p8-roundtrip-exact? 1/5]
;; => false : Bool

;; What did 1/3 become?
[p8-to-rat [p8-from-rat 1/3]]
;; => 11/32 : Rat  (close to 1/3 ≈ 0.333, but 11/32 = 0.34375)


;; --- Number theory: perfect numbers ---
;; A perfect number equals the sum of its proper divisors.

spec sum-divisors Int -> Int -> Int -> Int
defn sum-divisors [n i acc]
  if [int-lt i n]
    [if [int-eq [int-mod n i] 0]
      [sum-divisors n [int+ i 1] [int+ acc i]]
      [sum-divisors n [int+ i 1] acc]]
    acc

spec perfect? Int -> Bool
defn perfect? [n]
  [int-eq n [sum-divisors n 1 0]]

[perfect? 6]
;; => true : Bool  (1 + 2 + 3 = 6)

[perfect? 28]
;; => true : Bool  (1 + 2 + 4 + 7 + 14 = 28)

[perfect? 12]
;; => false : Bool


;; --- The whole tower in one expression ---
;; Let's compute with all four families:

;; Start with a Nat:
(def start : Nat 6N)

;; Convert to Int, square it:
(def as-int : Int [int* [from-nat start] [from-nat start]])

as-int
;; => 36 : Int

;; Convert to Rat, take reciprocal:
(def as-rat : Rat [rat/ 1/1 [from-int as-int]])

as-rat
;; => 1/36 : Rat

;; Convert to Posit8, see the approximation:
(def as-posit : Posit8 [p8-from-rat as-rat])

as-posit
;; => [posit8 27] : Posit8

;; And back to Rat to see what we got:
[p8-to-rat as-posit]
;; => 7/256 : Rat  (1/36 ≈ 0.0278, nearest Posit8 is 7/256 ≈ 0.0273)


;; ────────────────────────────────────────────────────────────
;; YOUR TURN:
;; 1. Find the next perfect number after 28. Hint: try [perfect? 496].
;; 2. Write a function that converts a Nat to a Posit32 via
;;    the full chain: Nat → Int → Rat → Posit32.
;; 3. Try [p8-roundtrip-exact? 1/8]. What about 1/16? 3/8?
;; ────────────────────────────────────────────────────────────


;; ========================================================================
;;  CONNECTIONS — Where to go next
;; ========================================================================
;;
;; You've seen the whole numeric tower! Here's where each piece
;; connects to the rest of the Prologos ecosystem:
;;
;; • prologos::data::nat      — Pure Prologos Nat ops (add, mult, pow, ...)
;; • Int/Rat/Posit primitives  — Built-in, fast (int+, rat*, p8-sqrt, ...)
;; • prologos::core::*-trait   — Eq, Ord, Add, Sub, Mul, Neg, Abs, Div
;; • prologos::core::from-trait / tryfrom-trait — Cross-family conversions
;; • prologos::core::fromint-trait / fromrat-trait — FromInt, FromRat
;; • prologos::core::numeric-bundles — Num, Fractional bundles
;; • prologos::core::additive-identity-trait — zero for a type
;; • prologos::core::multiplicative-identity-trait — one for a type
;; • prologos::core::generic-numeric-ops — sum, product, int-range
;; • prologos::core::identity-instances — zero/one for Nat, Int, Rat
;;
;; The From/TryFrom traits (not in prelude, require explicitly):
;;   From Nat Int, From Int Rat, From Nat Rat  — lossless
;;   From Posit8 Posit16/32/64                 — widening
;;   From Posit8/16/32/64 Rat                  — exact decode
;;   TryFrom Rat Posit8/16/32/64               — lossy encode
;;   TryFrom Int Posit8/16/32/64               — lossy encode
;;
;; Trait compatibility grid:
;;
;;   Trait     | Nat | Int | Rat | Posit*
;;   ----------+-----+-----+-----+-------
;;   Eq        |  ✓  |  ✓  |  ✓  |  ✓
;;   Ord       |  ✓  |  ✓  |  ✓  |  ✓
;;   Add       |  ✓  |  ✓  |  ✓  |  ✓
;;   Sub       |  ✓* |  ✓  |  ✓  |  ✓
;;   Mul       |  ✓  |  ✓  |  ✓  |  ✓
;;   Neg       |  ✗  |  ✓  |  ✓  |  ✓
;;   Abs       |  ✗  |  ✓  |  ✓  |  ✓
;;   Div       |  ✗  |  ✓† |  ✓  |  ✓
;;   FromInt   |  ✗  |  ✓  |  ✓  |  ✓
;;   FromRat   |  ✗  |  ✗  |  ✓  |  ✓
;;   Num       |  ✗  |  ✓  |  ✓  |  ✓
;;   Fractional|  ✗  |  ✗  |  ✓  |  ✓
;;
;;   * Nat Sub is saturating (min 0)
;;   † Int Div is truncating
;;
;; Explore: strings-tutorial-demo.prologos, map-tutorial-demo.prologos
;;
;; ========================================================================
;;  RECAP — The Numeric Tower at a Glance
;; ========================================================================
;;
;; Nat   42N             add mult pred sub pow double zero? le? lt?
;;                       gt? ge? nat-eq? min max clamp bool-to-nat
;;
;; Int   42              int+ int- int* int/ int-mod int-neg int-abs
;;                       int-lt int-le int-eq from-nat
;;
;; Rat   3/7             rat+ rat- rat* rat/ rat-neg rat-abs
;;                       rat-numer rat-denom rat-lt rat-le rat-eq from-int
;;
;; Posit (posit8 64)     p{N}+ p{N}- p{N}* p{N}/ p{N}-neg p{N}-abs
;;       ~3.14           p{N}-sqrt p{N}-lt p{N}-le
;;       ~2.718          p{N}-from-nat p{N}-from-int p{N}-from-rat p{N}-to-rat
;;                       (where N = 8, 16, 32, 64)
;;                       ~N syntax: ~42, ~3/7, ~3.14 (decimal → exact rational → Posit32)
;;
;; Traits  Add Sub Mul Neg Abs Div Eq Ord FromInt FromRat From TryFrom
;;         AdditiveIdentity MultiplicativeIdentity
;;
;; Bundles  Num := (Add Sub Mul Neg Eq Ord Abs FromInt)
;;          Fractional := (Num Div FromRat)
;;
;; Generics  sum product int-range generic functions via trait dicts
;;
;; Happy counting! 🔢
