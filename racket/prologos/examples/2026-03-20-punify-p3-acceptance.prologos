;; defr ancestor-lr [?a ?d] :tabled true
;;   &> (ancestor-lr mid d)
;;      (parent a mid)
;;   &> (parent a d)
;;
;; solve (ancestor-lr "alice" desc)
;; ;; => same results as right-recursive ancestor, but terminates

