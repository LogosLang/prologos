;;   [map [fn [binding] binding.child]]
;; ;; => '["bob" "carol"]

;; --- K3: defr using is with functional computation ---

defr double-parent [?p ?child ?age2]
  &> (parent p child)
     (is age2 [int* 2 1])

solve (double-parent "alice" child val)

