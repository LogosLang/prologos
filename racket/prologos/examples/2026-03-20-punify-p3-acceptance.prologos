;; ========================================================================
;; §I — ATMS MULTI-CLAUSE EXPLORATION
;; ========================================================================
;;
;; Tests the core Multiverse Multiplexer: atms-amb over clause alternatives.

;; --- I1: Multi-clause relation (baseline — already works via DFS) ---

defr color-of [?thing ?color]
  || "sky"   "blue"
     "grass" "green"
     "fire"  "red"
     "ocean" "blue"

solve (color-of thing "blue")
;; => [{:thing "sky"}, {:thing "ocean"}]

;; --- I2: Multi-clause with shared variable propagation ---

defr connects [?a ?b]
  || "x" "y"
     "y" "z"
     "x" "z"
     "z" "w"

defr two-hop [?a ?c]
  &> (connects a b)
     (connects b c)

solve (two-hop "x" dest)
;; => multiple solutions via different intermediate nodes

;; --- I3: Solver strategy comparison ---
;; ASPIRATIONAL — same query, different strategies, same results

;; def dfs-results := solve-with dfs-solver (two-hop "x" dest)
;; def atms-results := solve-with parallel-solver (two-hop "x" dest)
;; ;; Both should produce identical solution sets

;; --- I4: Single-clause fast path (no ATMS overhead) ---
;; Relations with one clause per arity should NOT trigger ATMS.

defr singleton [?x]
  &> (parent "alice" x)

solve (singleton child)
;; => [{:child "bob"}, {:child "carol"}]


;; ========================================================================
;; §J — NEGATION-AS-FAILURE IN SOLVER CONTEXT
;; ========================================================================

;; --- J1: Simple NAF (already works) ---

defr leaf-node [?name]
  &> (parent ?someone name)
     (not (parent name ?anyone))

solve (leaf-node who)
;; => leaf nodes: dave, eve, frank

;; --- J2: Stratified NAF with tabling ---
;; ASPIRATIONAL

;; defr wins [?player] :tabled true
;;   &> (moves player _)
;;      (not (loses player))
;;
;; defr loses [?player] :tabled true
;;   &> (moves player next-state)
;;      (wins next-state)

;; --- J3: WF semantics for cyclic negation ---
;; ASPIRATIONAL

;; defr even-cycle [] :tabled true
;;   &> (not (odd-cycle))
;;
;; defr odd-cycle [] :tabled true
;;   &> (not (even-cycle))
;;
;; solve-with wf-solver (even-cycle)
;; ;; => nil (unknown under WFS)


