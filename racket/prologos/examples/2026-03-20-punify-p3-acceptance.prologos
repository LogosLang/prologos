ns acceptance::punify-p3

;; ========================================================================
;;
;;   PUnify Part 3 Acceptance File
;;   The Multiverse Multiplexer — ATMS-World Solver on Propagators
;;
;;   STATUS: Phase 0 (Pre-Implementation — aspirational + baseline canary)
;;   Run via: process-file "racket/prologos/examples/2026-03-20-punify-p3-acceptance.prologos"
;;
;;   This file exercises:
;;     - solver definitions and solver-config knobs (§B)
;;     - solve-with and explain-with using named solvers (§C)
;;     - schema definitions (basic + composed + implicit map syntax) (§D)
;;     - selection definitions and field-level access (§E)
;;     - schema-validated defr (§F)
;;     - dot-access, postfix indexing, path algebras (§G)
;;     - tabling: left-recursive, answer modes, spec metadata (§H)
;;     - ATMS multi-clause exploration (§I)
;;     - negation-as-failure in solver context (§J)
;;     - cross-paradigm composition: solver × functional × schema (§K)
;;     - broad regression canary (§L)
;;
;;   Conventions:
;;     - Commented-out = aspirational or known-broken (annotated)
;;     - Uncommented = must pass today; regression if broken after any phase
;;     - [] for functional, () for relational keywords, <> for type-level
;;     - eval is implicit; col-0 application is implicit
;;     - Aspirational syntax: comment out, don't delete
;;
;; ========================================================================


;; ========================================================================
;; DATA TYPE DEFINITIONS
;; ========================================================================
;;
;; Constructors needed for relational tests.

data Color | red | green | blue
data Shape | circle Nat | rect Nat Nat | triangle Nat Nat Nat
;; LANGUAGE LIMITATION — parameterized ADTs: constructor field types not resolved
;; against type params (elaboration issue, not WS bug)
;; data Tree A | leaf A | node [Tree A] [Tree A]


;; ========================================================================
;; §A — EXISTING RELATIONAL BASELINE (must pass now)
;; ========================================================================
;;
;; Canary: if basic relational features regress, everything below is moot.

;; --- A1: Simple facts and solve ---

defr parent [?parent ?child]
  || "alice" "bob"
     "alice" "carol"
     "bob"   "dave"
     "bob"   "eve"
     "carol" "frank"

solve (parent "alice" child)
;; => [{"child" => "bob"}, {"child" => "carol"}]

;; --- A2: Rules with transitive closure ---

defr ancestor [?a ?d]
  &> (parent a d)
  &> (parent a mid)
     (ancestor mid d)

solve (ancestor "alice" desc)
;; => all descendants of alice

;; --- A3: solve-one ---

solve-one (parent "alice" child)
;; => Option: some binding

;; --- A4: Negation-as-failure ---
;; "childless" = a parent who is not themselves a child of anyone.

defr root-parent [?p]
  &> (parent p ?any-child)
     (not (parent ?anyone p))

solve (root-parent who)
;; => [{:who "alice"}]  (alice is a parent but not a child of anyone)


;; ========================================================================
;; §B — SOLVER DEFINITIONS
;; ========================================================================
;;
;; The `solver` form defines named solver configurations.
;; These expand to solver-config values at preparse.
;; All knobs from solver.rkt should be expressible.

;; --- B1: Default solver (minimal config) ---

solver my-default
  :strategy    auto
  :tabling     by-default

;; --- B2: Sequential depth-first solver ---

solver dfs-solver
  :strategy    depth-first
  :execution   sequential
  :tabling     off

;; --- B3: Debug solver with provenance ---

solver debug-solver
  :execution   sequential
  :strategy    auto
  :provenance  full
  :timeout     10000

;; --- B4: Parallel ATMS solver ---

solver parallel-solver
  :execution   parallel
  :threshold   4
  :strategy    atms
  :tabling     by-default

;; --- B5: Well-founded semantics solver ---

solver wf-solver
  :semantics   well-founded
  :strategy    auto
  :tabling     by-default

;; --- B6: Narrowing-aware solver ---

solver narrow-solver
  :strategy         auto
  :narrow-search    all
  :narrow-value-order smallest-domain


;; ========================================================================
;; §C — SOLVE-WITH AND EXPLAIN-WITH
;; ========================================================================
;;
;; Named solvers are used via solve-with and explain-with.
;; Also: inline overrides, solver + overrides.

;; --- C1: solve-with named solver ---

solve-with my-default (parent "alice" child)
;; => same as regular solve (stratified is default)

;; --- C2: solve-with inline overrides ---

solve-with {:tabling by-default} (parent "alice" child)

;; --- C3: solve-with named solver + inline overrides ---

solve-with my-default {:timeout 5000} (parent "alice" child)

;; --- C4: solve-with depth-first solver ---
;; This should produce identical results but via DFS, not ATMS.

solve-with dfs-solver (ancestor "alice" desc)

;; --- C5: explain-with for provenance ---
;; ASPIRATIONAL — explain-with may not be fully wired

;; explain-with debug-solver (ancestor "alice" "dave")
;; => derivation tree showing: parent alice bob, parent bob dave

;; --- C6: solve-with parallel ATMS ---
;; ASPIRATIONAL — parallel worldview exploration

;; solve-with parallel-solver (ancestor "alice" desc)

;; --- C7: solve-with well-founded ---

;; defr p-cyc []
;;   &> (not (q-cyc))
;;
;; defr q-cyc []
;;   &> (not (p-cyc))
;;
;; solve-with wf-solver (p-cyc)
;; => nil (both unknown under WFS)


;; ========================================================================
;; §D — SCHEMA DEFINITIONS
;; ========================================================================
;;
;; Schemas declare typed map shapes. spec : defn :: schema : defr.

;; --- D1: Basic schema ---

schema Point
  :x Int
  :y Int

;; --- D2: Schema with defaults ---

schema Config
  :host String :default "localhost"
  :port Int    :default 8080
  :debug Bool  :default false

;; --- D3: Closed schema (rejects extra keys) ---

schema Pixel :closed
  :x Int
  :y Int
  :color Color

;; --- D4: Schema with check predicates ---

;; schema Percentage
;;   :value Nat :check [le? _ 100N]

;; --- D5: Nested schema (schema referencing schema) ---

schema Address
  :street String
  :city   String
  :zip    Int

schema Person
  :name    String
  :age     Int
  :address Address

;; --- D6: Schema with implicit map syntax ---
;; FIXED — nested fields auto-generate sub-schemas (e.g., Employee__manager)

schema Employee
  :name    String
  :dept    String
  :salary  Int
  :manager
    :name String
    :level Int
  :address
    :street String
    :city   String
    :zip    Int

;; --- D7: Schema with generic type parameter ---
;; ASPIRATIONAL

;; schema Pair A B
;;   :fst A
;;   :snd B

;; --- D8: Construct schema-typed values ---

def origin : Point  := {:x 0 :y 0}
def cfg    : Config := {:host "api.example.com" :port 443 :debug true}

;; --- D9: Construct with defaults (omit defaulted fields) ---
;; ASPIRATIONAL — default-fill on construction

;; def default-cfg : Config := {}
;; ;; => {:host "localhost" :port 8080 :debug false}

;; def partial-cfg : Config := {:port 9090}
;; ;; => {:host "localhost" :port 9090 :debug false}


;; ========================================================================
;; §E — SELECTION DEFINITIONS
;; ========================================================================
;;
;; Selections declare field-level access policies over schemas.

;; --- E1: Basic selection (requires subset of fields) ---
;; FIXED — selection preparse now flattens WS-grouped kv-pairs

selection NameOnly from Person
  :requires [:name]

selection ContactInfo from Person
  :requires [:name :address]

;; --- E2: Deep path selection ---
;; FIXED — reconstitute-selection-paths handles $dot-access chains

selection ZipOnly from Person
  :requires [:address.zip]

;; --- E3: Selection composition via :includes ---
;; FIXED — flatten + reconstitute handles :includes vector args

selection Extended from Person
  :includes [ContactInfo]
  :requires [:age]

;; --- E4: Selection with :provides ---
;; ASPIRATIONAL — :provides declares what the selection exposes

;; selection PublicProfile from Person
;;   :requires [:name :age]
;;   :provides [:name :age]

;; --- E5: Function typed with selection ---
;; ASPIRATIONAL — selection restricts field access at type level

;; spec get-person-name NameOnly -> String
;; defn get-person-name [p]
;;   p.name

;; --- E6: Selection with wildcard paths ---
;; ASPIRATIONAL

;; selection AllAddressFields from Person
;;   :requires [:address.*]

;; --- E7: Selection with globstar ---
;; ASPIRATIONAL

;; selection AllNested from Person
;;   :requires [:address.**]


;; ========================================================================
;; §F — SCHEMA-VALIDATED DEFR
;; ========================================================================
;;
;; defr with : SchemaName links a relation to its schema.
;; Facts are type-checked against schema field types.
;; Query results use field names, not positions.

;; --- F1: Schema-typed relation with facts ---
;; ASPIRATIONAL — schema-validated defr not yet wired

;; defr point-db : Point
;;   || 0 0
;;      1 2
;;      3 4
;;      10 10

;; --- F2: Query schema-typed relation ---
;; ASPIRATIONAL

;; solve (point-db x 0)
;; ;; => [{:x 0}]  — result uses field names from schema

;; --- F3: Schema-typed relation with rules ---
;; ASPIRATIONAL

;; schema Edge
;;   :from String
;;   :to   String
;;
;; defr edge : Edge
;;   || "a" "b"
;;      "b" "c"
;;      "c" "d"
;;
;; defr reachable : Edge
;;   &> (edge from to)
;;   &> (edge from mid)
;;      (reachable mid to)

;; --- F4: Schema-typed query with named results ---
;; ASPIRATIONAL

;; solve (reachable from "d")
;; ;; => [{:from "a"}, {:from "b"}, {:from "c"}]

;; --- F5: Schema type error on malformed facts ---
;; ASPIRATIONAL — should be a compile-time type error

;; defr bad-point : Point
;;   || "not-a-int" 0
;;   ;; TYPE ERROR: :x expects Int, got String

;; --- F6: Schema + defaults in defr ---
;; ASPIRATIONAL

;; defr config-db : Config
;;   || "prod" 443 true
;;      "dev"  _ _
;;   ;; The _ positions should be filled by schema defaults

;; --- F7: Closed schema rejects extra columns ---
;; ASPIRATIONAL

;; defr bad-pixel : Pixel
;;   || 0N 0N red 0.5
;;   ;; ERROR: Pixel is :closed — 4 values for 3 fields


;; ========================================================================
;; §G — DOT-ACCESS, POSTFIX INDEXING, PATH ALGEBRAS
;; ========================================================================
;;
;; These test map navigation syntax — much of this is expected to be
;; broken at L3 WS but represents target syntax.

;; --- G1: Basic dot-access ---

def user := {:name "alice" :age 30}

user.name
;; => "alice"

user.age
;; => 30

;; --- G2: Chained dot-access on nested maps ---
;; WORKS with homogeneous inner map types. Heterogeneous (mixed Int/String)
;; hits QTT multiplicity bug — use schema-typed nested maps instead.

def nested := {:config {:host "localhost" :port "8080"}}

nested.config
;; => {:host "localhost" :port "8080"}

nested.config.host
;; => "localhost"

;; --- G3: Dot-access on schema-typed values ---

origin.x
;; => 0

origin.y
;; => 0

;; --- G4: Dot-access on function result ---
;; WORKS — dot-access chains on expression results (plain maps, not schema-typed)

[map-assoc user :role "admin"].role
;; => "admin"

;; --- G5: Keyword dot-access ---
;; FIXED — $dot-key now handled in rewrite-dot-access fold-left

user.:name
;; => "alice"

;; --- G6: Nil-safe dot-access ---
;; ASPIRATIONAL — #. short-circuits on nil

;; def maybe-user := {:address nil}
;; maybe-user#.address#.city
;; ;; => nil (no error)
;;
;; ;; Versus regular dot-access which would throw:
;; ;; maybe-user.address.city  → ERROR

;; --- G7: Standalone nil-safe key access ---
;; ASPIRATIONAL

;; #:name
;; ;; => fn (x : _) (nil-safe-get x :name)

;; --- G8: Postfix bracket indexing ---
;; WORKS — list postfix indexing at L3

def xs := '[1 2 3 4 5]

xs[0]
;; => 1

xs[2]
;; => 3

;; --- G9: Postfix indexing on map with keyword ---

def m := {:a 1 :b 2 :c 3}

m[:a]
;; => 1

m[:c]
;; => 3

m.b
;; => 2


;; --- G10: Chained postfix indexing ---
;; WORKS — chained postfix indexing on nested lists

def matrix := (cons '[1 2 3] (cons '[4 5 6] (cons '[7 8 9] nil)))

matrix[0][1]
;; => 2

matrix[2][0]
;; => 7

;; --- G11: Mixed dot-access and postfix indexing ---
;; ASPIRATIONAL

;; def users := '[{:name "alice" :age 30N} {:name "bob" :age 25N}]
;; users[0].name
;; ;; => "alice"
;;
;; users[1].age
;; ;; => 25N

;; --- G12: Path algebra — get-in ---
;; ASPIRATIONAL — :a.b.c auto-desugars to nested map-get before get-in sees it;
;; needs path-descriptor syntax or quoting to prevent premature desugaring.
;; Also: nested map literals without annotation hit inference limitation.

;; def deep := {:a {:b {:c 42}}}
;;
;; (get-in deep :a.b.c)
;; ;; => 42

;; --- G13: Path algebra — branching ---
;; ASPIRATIONAL

;; def record := {:name "alice" :address {:zip 10001N :city "NYC" :state "NY"}}
;; (get-in record :address.{zip city})
;; ;; => {:zip 10001N :city "NYC"}

;; --- G14: Path algebra — update-in ---

;; (update-in deep :a.b.c [fn [n] [int+ n 1]])
;; ;; => {:a {:b {:c 43}}}

;; --- G15: Path algebra — wildcard ---
;; ASPIRATIONAL

;; def team := {:alice {:score 95N} :bob {:score 87N} :carol {:score 92N}}
;; (get-in team :*.score)
;; ;; => {:alice 95N :bob 87N :carol 92N}

;; --- G16: Path algebra — globstar ---
;; ASPIRATIONAL

;; def tree-data := {:a {:b {:c 1 :d 2} :e {:f 3}}}
;; (get-in tree-data :**)
;; ;; => all leaf values

;; --- G17: Postfix indexing in pipeline ---
;; ASPIRATIONAL

;; |> '[10 20 30 40]
;;   [fn [xs] xs[2]]
;; ;; => 30

;; --- G18: Dot-access in pipeline ---
;; ASPIRATIONAL

;; |> {:name "alice" :age 30}
;;   :name
;; => "alice"

;; :name {:name "alice" :age 30}


;; ========================================================================
;; §H — TABLING
;; ========================================================================
;;
;; Tabling prevents left-recursive divergence and memoizes shared subgoals.
;; Part 3 Phase 5 delivers this. Most tests here are aspirational.

;; --- H1: Left-recursive ancestor should terminate ---
;; Currently: ancestor uses right-recursive rule; left-recursive would diverge.
