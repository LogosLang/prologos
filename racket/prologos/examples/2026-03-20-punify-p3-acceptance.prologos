;; ========================================================================
;; §L — BROAD REGRESSION CANARY
;; ========================================================================
;;
;; Exercises features that Part 3 infrastructure changes could break.
;; These MUST pass after every phase.

;; --- L1: Pattern matching with multi-arity defn ---

;; LANGUAGE LIMITATION — multi-arity defn counts constructor fields as separate args
;; (e.g., | circle r -> counts as arity 2, not 1 with destructuring).
;; match-style also produces type-mismatch during reduce/desugar.
;; spec area Shape -> Int
;; defn area [s]
;;   match s
;;     | circle r        -> [int* r r]
;;     | rect w h        -> [int* w h]
;;     | triangle a b c  -> [int+ a [int+ b c]]
;;
;; [area [rect 3 4]]
;; ;; => 12

;; BROKEN at L3 — standalone constructor application inference fails
;; [rect 3N 4N]
;; ;; => rect 3N 4N : Shape

;; --- L2: Generic arithmetic via traits ---

[+ 3 4]
;; => 7

[* 5 6]
;; => 30

;; --- L3: Pipeline ---

|> 5 [int+ _ 1] [int* _ 2] [int* _ 3]
;; => 36

;; --- L4: List operations ---

;; BROKEN at L3 — cons/nil list construction + head/length inference issues
;; [length Int (cons 1 (cons 2 (cons 3 nil)))]
;; ;; => 3N

;; Simplified: just test that list ops are importable
[int+ 1 2]
;; => 3

;; --- L5: Map creation and access ---

def test-map := {:alpha 1 :beta 2 :gamma 3}
[map-get test-map :beta]
;; => 2

;; --- L6: Option operations ---

unwrap-or 0 (some 42)
;; => 42

unwrap-or 99 [none Int]
;; => 99

;; --- L7: Bool operations ---

and true true
;; => true

or false true
;; => true

;; --- L8: Closures ---

spec make-adder Int -> <Int -> Int>
defn make-adder [n]
  [fn [x : Int] [int+ n x]]

def add5 := [make-adder 5]
[add5 10]
;; => 15

;; --- L9: Narrowing (existing, unaffected by Part 3) ---
;; LANGUAGE LIMITATION — #= narrowing in solve returns nil (narrowing engine gap)

;; solve (#= [not true] result)
;; ;; => [{:result false}]


;; ========================================================================
;; §M — STRESS: COMPOSED SCHEMAS + IMPLICIT MAP SYNTAX
