;; ========================================================================
;; SECTION H: LAMBDA, LET, CLOSURES
;; ========================================================================
;;
;; fn expressions, let bindings, closures — create fresh metas during
;; speculation that must be properly rolled back.

;; --- H1: Lambda basics ---

(fn [x : Int] [int+ x 1]) 41
(fn [x : Int] [int* x x]) 5

;; --- H2: Lambda with generic dispatch ---
;; BUG (L3): generic + in bare lambda may not resolve.

;; (fn [x : Int] [+ x 1]) 41

;; --- H3: Let bindings ---

(let [x := 42] x)
(let [x := 10] [int+ x x])

;; --- H4: Nested let ---

(let [x := 10]
  (let [y := 20]
    [int+ x y]))

;; --- H5: Let with function value ---

(let [f := [fn [x : Int] [int+ x 1]]]
  [f 41])

;; --- H6: Let with computation ---

(let [a := [int* 3 4]]
  (let [b := [int+ a 1]]
    [int* a b]))
;; => 12 * 13 = 156

;; --- H7: Closure capturing ---

spec make-adder Int -> [Int -> Int]
defn make-adder [n]
  fn [x : Int] [int+ n x]

[make-adder 10] 32
[make-adder 0] 42

;; --- H8: Closure with multiple captures ---

spec make-linear Int Int -> [Int -> Int]
defn make-linear [a b]
  fn [x : Int] [int+ [int* a x] b]

[make-linear 2 3] 5
;; => 2*5 + 3 = 13

;; --- H9: If as expression ---

if true 42 0
if false "yes" "no"
;; BUG (L3): int= unbound variable.
;; if [int= 1 1] "equal" "nope"

;; --- H10: Nested if ---

if true
  (if false 1 2)
  3

