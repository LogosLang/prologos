;; ========================================================================
;;
;;   Track 4 Acceptance File — ATMS Speculation (TMS-in-Network)
;;
;;   STATUS: Phase 0 (Pre-Implementation Baseline)
;;   Run via: process-file "racket/prologos/examples/2026-03-16-track4-acceptance.prologos"
;;
;;   Track 4 is an infrastructure track (no syntax changes). This file
;;   broadly exercises Prologos speculation-heavy features in ideal WS
;;   syntax to confirm no regressions from the TMS-in-network migration.
;;   Speculation-heavy = union types, map widening, Church folds, trait
;;   resolution — anything that triggers with-speculative-rollback.
;;
;;   Conventions:
;;     - Union types: `<A | B>` — angle brackets for type-level grouping
;;     - A? sugar for `<A | Nil>`
;;     - Uncurried type signatures: `spec f A B -> C`
;;     - Direct pattern dispatch on defn preferred
;;     - Generic dispatch: `+`, `-`, `*`, `/` for trait-resolved ops
;;     - Full prelude — exercise the standard library
;;     - Commented-out = aspirational ideal; annotated with BUG/BLOCKED
;;     - Uncommented = must pass today; regression if broken
;;     - Nat ONLY for inductive/structural patterns
;;     - Int for computation, Num generics for polymorphism
;;
;;   Sections:
;;     A. Union type speculation (single-level)
;;     B. Nested union speculation (union-of-unions)
;;     C. Map value widening
;;     D. Generic dispatch (+, -, *, /, Eq, Ord)
;;     E. Dependent types — inductive Nat patterns
;;     F. Numeric tower (Int, Rat, Posit)
;;     G. Higher-order functions under speculation
;;     H. Lambda, let, closures
;;     I. Data types, Option, Result, A? sugar
;;     J. Collections (List, PVec, Set, Map)
;;     K. Quote, quasiquote, macros
;;     L. Combined stress patterns
;;
;; ========================================================================


ns acceptance::track4


;; ========================================================================
;; SECTION A: UNION TYPE SPECULATION (SINGLE-LEVEL)
;; ========================================================================
;;
;; Union type checking triggers with-speculative-rollback.
;; The checker tries the left branch; on failure, rolls back and tries right.
;; After Track 4: rollback via TMS retraction instead of save/restore.

;; --- A1: Simple union values ---

def a1-int : <Int | String> := 42
def a1-str : <Int | String> := "hello"
a1-int
a1-str

;; --- A2: Union in function return ---

spec tag-int Int -> <Int | String>
defn tag-int [x] x

spec tag-str String -> <Int | String>
defn tag-str [s] s

tag-int 10
tag-str "world"

;; --- A3: Union with Bool ---

def a3-val : <Bool | Int> := true
def a3-num : <Bool | Int> := 99

;; --- A4: Three-way union ---

def a4-int  : <Int | String | Bool> := 42
def a4-str  : <Int | String | Bool> := "hello"
def a4-bool : <Int | String | Bool> := true

;; --- A5: Union as function parameter ---

spec accept-either <Int | String> -> Bool
defn accept-either [_] true

accept-either 42
accept-either "hi"

;; --- A6: Union in both parameter and return ---
;; BUG (L3): type mismatch on identity function with union return type.

;; spec echo-union <Int | String> -> <Int | String>
;; defn echo-union [x] x
;;
;; echo-union 42
;; echo-union "reflected"

;; --- A7: Union narrowing via direct dispatch ---
;; IDEAL: direct pattern dispatch on union values.
;; BUG (L3): union dispatch not wired at file level.

;; spec describe <Int | String> -> String
;; defn describe
;;   | [(the Int n)]    -> "number"
;;   | [(the String s)] -> s
;;
;; describe 42
;; describe "hi"

;; --- A8: A? nullable sugar ---
;; IDEAL: `Int?` desugars to `<Int | Nil>`.
;; BUG (L3): A? sugar may not work at file level.

;; def a8-val  : Int? := 42
;; def a8-nil  : Int? := nil
;; def a8-str  : String? := "maybe"
;; def a8-none : String? := nil


;; ========================================================================
;; SECTION B: NESTED UNION SPECULATION (UNION-OF-UNIONS)
;; ========================================================================
;;
;; Nested with-speculative-rollback. Checking against <<Int | Bool> | String>
;; triggers outer speculation (try left = <Int | Bool>), inner speculation.
;; After Track 4: TMS cell tree mirrors nesting via recursive CHAMP.

;; --- B1: Two-level nesting ---

def b1-int  : <<Int | Bool> | String> := 42
def b1-bool : <<Int | Bool> | String> := false
def b1-str  : <<Int | Bool> | String> := "nested"

;; --- B2: Three-level nesting (stress) ---

def b2-deep : <<<Int | Bool> | String> | Char> := 7

;; --- B3: Nested union in function ---

spec classify-deep Int -> <<Int | Bool> | String>
defn classify-deep [x] x

classify-deep 100

;; --- B4: Nested union parameter ---

spec accept-nested <<Int | Bool> | String> -> Bool
defn accept-nested [_] true

accept-nested 42
accept-nested false
accept-nested "yes"

;; --- B5: Right-associated nesting ---

def b5 : <Int | <String | Bool>> := "right"


;; ========================================================================
;; SECTION C: MAP VALUE WIDENING
;; ========================================================================
;;
;; Map-value-widening speculation: checker speculatively checks if new
;; value fits existing map type. Failure triggers type widening.

;; --- C1: Homogeneous string map ---

def c1 := {:name "alice" :role "admin"}
c1

;; --- C2: Int-valued map ---

def c2 := {:x 1 :y 2 :z 3}
c2

