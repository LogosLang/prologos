;; --- L7: Identity polymorphism ---

spec my-id {A} A -> A
  :implicits [A]
defn my-id [x] x

my-id 42
my-id "hello"
my-id true
my-id 1/2
my-id zero

;; --- L8: Const polymorphism ---

spec my-const {A B} A -> B -> A
  :implicits [A B]
defn my-const [a _] a

my-const 42 "ignored"
my-const true 0

