;; ========================================================================
;; SECTION G: HIGHER-ORDER FUNCTIONS UNDER SPECULATION
;; ========================================================================

;; --- G1: map ---

map [fn [x] [int+ x 1]] '[1 2 3]
map [fn [x] [int* x x]] '[1 2 3 4]

;; --- G2: map with generic + ---
;; BUG (L3): generic + in lambda may not resolve in map context.

;; map [fn [x] [+ x 1]] '[1 2 3]
;; map [fn [x] [* x x]] '[1 2 3 4]

;; --- G3: foldl ---

;; BUG (L3): parse error "Expected binder [x <T>]" — foldl lambda with 2 args.
;; foldl [fn [acc x] [int+ acc x]] 0 '[1 2 3 4 5]
;; foldl [fn [acc _] [int+ acc 1]] 0 '[1 2 3 4 5]

;; --- G4: foldl with generic ---

;; foldl [fn [acc x] [+ acc x]] 0 '[1 2 3 4 5]

;; --- G5: compose ---

spec inc Int -> Int
defn inc [x] [int+ x 1]

spec dbl Int -> Int
defn dbl [x] [int* x 2]

spec sqr Int -> Int
defn sqr [x] [int* x x]

compose inc dbl 5
compose dbl inc 5
compose sqr inc 3

;; --- G6: Pipe ---

|> 5 inc dbl
|> 10 dbl inc
|> 3 inc sqr

;; --- G7: Triple compose ---

|> 2 inc dbl sqr
;; => ((2+1)*2)^2 = 36

;; --- G8: Apply and twice ---

spec apply-fn [Int -> Int] Int -> Int
defn apply-fn [f x] [f x]

apply-fn inc 41
apply-fn sqr 6

spec twice-fn [Int -> Int] Int -> Int
defn twice-fn [f x] [f [f x]]

twice-fn inc 40
twice-fn dbl 3

