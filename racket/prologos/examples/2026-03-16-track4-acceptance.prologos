;; ========================================================================
;; SECTION E: DEPENDENT TYPES — INDUCTIVE NAT PATTERNS
;; ========================================================================
;;
;; Nat for: inductive proofs, structural recursion, Peano arithmetic.
;; Direct dispatch preferred where it works.

;; --- E1: Boolean direct dispatch ---

spec my-not Bool -> Bool
defn my-not
  | true  -> false
  | false -> true

my-not true
my-not false

spec my-and Bool Bool -> Bool
defn my-and [a b]
  | true  b  -> b
  | false _  -> false

my-and true true
my-and true false
my-and false true

spec my-or Bool Bool -> Bool
defn my-or [a b]
  | true  _  -> true
  | false b  -> b

my-or false true
my-or false false

;; --- E2: Peano add ---
;; BUG (L3): direct multi-clause at file level.
;; IDEAL:
;; spec peano-add Nat Nat -> Nat
;; defn peano-add
;;   | [x zero]    -> x
;;   | [x (suc k)] -> suc [peano-add x k]

spec peano-add Nat Nat -> Nat
defn peano-add [x y]
  match y
    | zero  -> x
    | suc k -> suc [peano-add x k]

peano-add 2N 3N
peano-add 0N 0N
peano-add 1N 1N

;; --- E3: Peano mul ---

spec peano-mul Nat Nat -> Nat
defn peano-mul [x y]
  match y
    | zero  -> zero
    | suc k -> peano-add x [peano-mul x k]

peano-mul 2N 3N
peano-mul 3N 3N

;; --- E4: Mutual recursion ---
;; BUG (L3): forward reference to odd? at file level — mutual recursion not supported.

;; spec even? Nat -> Bool
;; defn even? [n]
;;   match n
;;     | zero  -> true
;;     | suc k -> odd? k
;;
;; spec odd? Nat -> Bool
;; defn odd? [n]
;;   match n
;;     | zero  -> false
;;     | suc k -> even? k
;;
;; even? 0N
;; even? 4N
;; odd? 3N
;; odd? 2N

;; --- E5: Nat to Int ---

spec nat-to-int Nat -> Int
defn nat-to-int [n]
  match n
    | zero  -> 0
    | suc k -> [+ 1 [nat-to-int k]]

nat-to-int 0N
nat-to-int 5N

;; --- E6: Nat max ---

spec nat-max Nat Nat -> Nat
defn nat-max [x y]
  if [ord-gt nat-ord x y] x y

nat-max 3N 5N
nat-max 5N 3N

