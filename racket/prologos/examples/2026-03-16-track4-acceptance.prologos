[/ 100 4]
[/ 42 6]

;; --- D5: Generic + on Rat ---

[+ 1/2 1/3]
[+ 0/1 5/7]

;; --- D6: Generic * on Rat ---

[* 2/3 3/5]
[* 1/2 1/2]

;; --- D7: Generic - on Rat ---

[- 3/4 1/4]

;; --- D8: Chained generic arithmetic ---

[+ [* 3 4] [- 10 3]]
[* [+ 2 3] [+ 4 5]]
[+ [+ 1 2] [+ 3 [+ 4 5]]]

;; --- D9: Deeply nested generic ops ---

[+ [* [+ 1 2] [- 5 2]] [/ 100 10]]
;; => (1+2)*(5-2) + 100/10 = 9 + 10 = 19

;; --- D10: Eq on Nat (explicit dict) ---

eq-check nat-eq 2N 2N
eq-check nat-eq 0N 1N
eq-neq nat-eq 0N 1N

;; --- D11: Ord on Nat (explicit dict) ---

ord-compare nat-ord 1N 2N
ord-lt nat-ord 0N 1N
ord-gt nat-ord 2N 0N

