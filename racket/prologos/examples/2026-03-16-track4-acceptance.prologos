spec f1 Int -> Int
defn f1 [x] [int+ x 1]

spec f2 Int -> Int
defn f2 [x] [int* x 2]

spec f3 Int -> Int
defn f3 [x] [int- x 3]

f1 [f2 [f3 [f1 [f2 10]]]]

;; --- L3: Multiple speculation per expression ---

spec both-unions <Int | String> -> <Int | Bool> -> Int
defn both-unions [_ _] 0

both-unions 42 99
both-unions "hello" true

