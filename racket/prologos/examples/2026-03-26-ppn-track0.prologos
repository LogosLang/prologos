;; ===================================================================
;; Section 6: Data types — algebraic, with inference
;; ===================================================================
ns ppn-s6

;; Simple sum type
data Color := red | green | blue

;; Product type
data Point := point [x : Int] [y : Int]
def origin := [point 0 0]
def p := [point 3 4]

;; IDEAL: pattern match on data type
;; spec color-name Color -> String
;; defn color-name
;;   | red   -> "red"
;;   | green -> "green"
;;   | blue  -> "blue"
;; [color-name red]

;; Recursive data type
data Tree := leaf | node [val : Int] [left : Tree] [right : Tree]
def t := [node 1 [node 2 leaf leaf] [node 3 leaf leaf]]

;; IDEAL: tree fold
;; spec tree-sum Tree -> Int
;; defn tree-sum
;;   | leaf           -> 0
;;   | [node v l r]   -> [int+ v [int+ [tree-sum l] [tree-sum r]]]
;; [tree-sum t]


;; ===================================================================
;; Section 7: Module imports + qualified access
;; ===================================================================
ns ppn-s7

;; Standard prelude is auto-imported
[length '[1 2 3]]
[head '[10 20 30]]

;; Qualified module access
[str::length "hello"]
[char::code 'A']

;; IDEAL: selective import
;; (imports [prologos::data::nat :as nat :refer [zero?]])
;; [zero? 0N]


;; ===================================================================
;; Section 8: Higher-order functions + closures
;; ===================================================================
ns ppn-s8

;; Function returning function
spec make-adder Int -> [Int -> Int]
defn make-adder [n]
  [fn [x : Int] [int+ n x]]

def add5 := [make-adder 5]
[add5 10]
[add5 20]

;; Function composition
def inc := [fn [x : Int] [int+ x 1]]
def dbl := [fn [x : Int] [int* x 2]]
|> 5 inc dbl inc

;; IDEAL: compose operator
;; def inc-then-dbl := [compose dbl inc]
;; [inc-then-dbl 5]  ;; (5+1)*2 = 12


;; ===================================================================
;; Section 9: Option + Result — monadic-style chaining
;; ===================================================================
ns ppn-s9

def x := [some 42]
def y := none

;; Option operations
[some? x]
[none? y]

;; IDEAL: option chaining / map
;; [opt::map [int+ _ 1] x]  ;; some 43
;; [opt::map [int+ _ 1] y]  ;; none

;; Result
def ok-val := [ok 42]
def err-val := [err "something went wrong"]
[ok? ok-val]
[err? err-val]


;; ===================================================================
;; Section 10: Subtyping — numeric hierarchy
;; ===================================================================
ns ppn-s10

;; Subtype relationships
;; Int <: Rat should hold
def i := 42
def r := 3/4

;; IDEAL: implicit coercion
;; spec add-rat Rat -> Rat -> Rat
;; defn add-rat [x y] [rat+ x y]
;; [add-rat 42 3/4]  ;; [BROKEN?: implicit Int->Rat coercion]


;; ===================================================================
;; Section 11: Dependent types — basic Pi/Sigma
;; ===================================================================
ns ppn-s11

;; Dependent pair (Sigma)
;; IDEAL: Sigma type
;; def pair := (the <(x : Int) * [x > 0]> (3, refl))
;; [BROKEN?: Sigma type syntax in WS mode]

;; Universe levels
def ty := (the [Type 0] Int)


;; ===================================================================
;; Section 12: Eq proofs — equality type
;; ===================================================================
ns ppn-s12

;; Reflexivity
def p := (the [Eq Int 42 42] refl)

;; Symmetry
def q := [sym p]

;; Transitivity
def r := [trans p q]


;; ===================================================================
;; Section 13: Quote + quasiquote — code as data
;; ===================================================================
ns ppn-s13

;; Quote — produces Datum values
def d := '(hello world)
def e := '42
def f := '(+ 1 2)

;; IDEAL: quasiquote with unquote
;; def g := `(result is ,(the Int 42))
;; [BROKEN?: quasiquote WS syntax]


;; ===================================================================
;; Section 14: String operations — char, string, interpolation
;; ===================================================================
ns ppn-s14

def s := "hello"
[str::length s]
[str::to-upper s]
[str::concat s " world"]

;; Char operations
def ch := 'A'
[char::code ch]

;; IDEAL: string interpolation
;; def name := "world"
;; def greeting := "hello ${name}"  ;; [BROKEN?: string interpolation syntax]


;; ===================================================================
;; Section 15: Dot access — map keys
;; ===================================================================
ns ppn-s15

def user := {:name "alice" :age 30 :active true}
user.name
user.age
user.active

;; Nested dot access
def org := {:lead {:name "bob" :role "cto"}}
;; IDEAL: org.lead.name  ;; [BROKEN?: nested dot access chain]


;; ===================================================================
;; Section 16: Pipeline + partial application
;; ===================================================================
ns ppn-s16

;; Pipeline
|> '[1 2 3 4 5]
   [map [int* _ 2]]
   [filter [fn [x : Int] [int-gt x 4]]]
   length

;; IDEAL: longer pipeline with mixed operations
;; |> "hello world"
;;    str::to-upper
;;    str::length
;; [BROKEN?: pipeline with qualified module functions]


;; ===================================================================
;; Section 17: Multi-body defn — complex dispatch
;; ===================================================================
ns ppn-s17

spec fib Int -> Int
defn fib
  | 0 -> 0
  | 1 -> 1
  | n -> [int+ [fib [int- n 1]] [fib [int- n 2]]]
[fib 10]

;; IDEAL: multi-argument multi-body
;; spec zip-with {A B C : Type} [A -> B -> C] -> [List A] -> [List B] -> [List C]
;; defn zip-with
;;   | f [cons a as] [cons b bs] -> [cons [f a b] [zip-with f as bs]]
