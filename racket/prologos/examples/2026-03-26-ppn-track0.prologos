;; PPN Track 0: Parse Domain Lattice Design — Acceptance File
;; Run with: process-file "examples/2026-03-26-ppn-track0.prologos"
;;
;; PURPOSE: Stress-test EVERY syntax form and composition the language supports.
;; PPN Track 0 defines lattices for parsing — it doesn't change any pipeline code.
;; This file establishes a BASELINE of what works and what breaks, so that
;; Tracks 1-4 (which DO change the pipeline) can detect regressions.
;;
;; STRATEGY:
;; 1. Ideal syntax written first — the way we THINK things should work
;; 2. If it doesn't work, commented out with [BROKEN: reason]
;; 3. Working alternative below the commented version
;; 4. Every toplevel form from the grammar is exercised
;; 5. Compositions and edge cases designed to BREAK the language
;;
;; The gap between ideal and working IS the PPN Track 7 motivation:
;; user-defined grammar extensions that fix these gaps.

;; ===================================================================
;; Section 1: Basic type inference + arithmetic
;; ===================================================================
ns ppn-s1

;; Simple inference
def a := 42
def b := [int+ a 10]
def c := [int* a b]

;; Nat arithmetic (inductive)
def n := 3N
def m := [suc [suc 0N]]

;; Bool operators — nested
def p := [and true [or false [not true]]]

;; String operations
def greeting := "hello world"
def upper := [str::to-upper greeting]
def len := [str::length greeting]

;; Generic arithmetic via traits
[+ 3 4]
[* 5 6]
[- 10 3]

;; Pipeline operator
|> 5 [fn [x : Int] [int+ x 1]] [fn [x : Int] [int* x 2]]


;; ===================================================================
;; Section 2: Collections — lists, maps, sets, pvecs
;; ===================================================================
ns ppn-s2

;; List literals and operations
def xs := '[1 2 3 4 5]
def ys := [map [fn [x : Int] [int+ x 10]] xs]
[length ys]
[head xs]
[tail xs]
;; IDEAL: [filter [fn [x : Int] [int> x 2]] xs]
;; [BROKEN: > in identifier parsed as angle-bracket close — PPN Track 1 lexer issue]
[filter [fn [x : Int] [int-gt x 2]] xs]
[foldr [fn [x : Int] [acc : Int] [int+ x acc]] 0 xs]

;; Partial application (preferred over lambda)
def doubled := [map [int* _ 2] xs]

;; Map literals and access
def m := {:name "alice" :age 42}
m.name
m.age

;; Set operations
def s := [set-from-list '[1 2 3 2 1]]

;; PVec operations
;; IDEAL: def pv := #[10 20 30]  ;; [BROKEN: #[ not a recognized reader macro — no PVec literal syntax]
;; Workaround: pvec-from-list-fn
def pv := [pvec-from-list-fn '[10 20 30]]


;; ===================================================================
;; Section 3: Polymorphic functions + implicit arguments
;; ===================================================================
ns ppn-s3

;; Explicit spec + defn with implicit type parameter
spec my-id {A : Type} A -> A
defn my-id [x] x
[my-id 42]
[my-id "hello"]
[my-id true]

;; Multi-argument polymorphic
spec my-const {A B : Type} A -> B -> A
defn my-const [x y] x
[my-const 42 "ignored"]

;; Higher-order: function as argument
spec apply-twice {A : Type} [A -> A] -> A -> A
defn apply-twice [f x] [f [f x]]
[apply-twice [fn [x : Int] [int+ x 1]] 10]

;; IDEAL: uncurried partial application
;; [apply-twice [int+ _ 1] 10]  ;; [BROKEN: partial application of int+ needs explicit lambda wrapper]
[apply-twice [fn [x : Int] [int+ x 1]] 10]


;; ===================================================================
;; Section 4: Pattern matching — multi-arity defn
;; ===================================================================
ns ppn-s4

;; Multi-arity defn (preferred over match)
spec is-zero Nat -> Bool
defn is-zero
  | zero    -> true
  | [suc _] -> false
[is-zero 0N]
[is-zero 3N]

;; Nested patterns
spec list-head-or-default {A : Type} [List A] -> A -> A
defn list-head-or-default
  | [cons h _] _ -> h
  | nil        d -> d
[list-head-or-default '[1 2 3] 0]
[list-head-or-default nil 99]

;; IDEAL: deep nested pattern
;; spec deep-match [List [List Int]] -> Int
;; defn deep-match
;;   | [cons [cons x _] _] -> x
;;   | _                   -> 0
;; [BROKEN?: nested list-of-list pattern — test if this works]
;; [deep-match '['[10 20] '[30 40]]]

;; Boolean match (prefer multi-arity over if)
spec negate Bool -> Bool
defn negate
  | true  -> false
  | false -> true
[negate true]


