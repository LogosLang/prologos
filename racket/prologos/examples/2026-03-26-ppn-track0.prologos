;; ===================================================================
;; Section 18: Let expressions
;; ===================================================================
ns ppn-s18

;; IDEAL: let binding
;; let x := 10
;; let y := [int+ x 5]
;; [int* x y]

;; What works: def at top level
def x := 10
def y := [int+ x 5]
[int* x y]


;; ===================================================================
;; Section 19: Cond / when / do — control flow
;; ===================================================================
ns ppn-s19

;; IDEAL: cond expression
;; cond
;;   | [int-gt 5 3] -> "greater"
;;   | [int= 5 3] -> "equal"
;;   | true       -> "less"

;; IDEAL: when
;; when true "yes"

;; What works: pattern match on bool
(match true | true -> "yes" | false -> "no")


;; ===================================================================
;; Section 20: QTT multiplicities
;; ===================================================================
ns ppn-s20

;; Linear function (multiplicity 1)
spec use-once {:1 A : Type} A -> A
defn use-once [x] x
[use-once 42]

;; Erased (multiplicity 0)
spec erased-arg {:0 A : Type} A -> Int
defn erased-arg [_] 42
[erased-arg "this is erased"]


