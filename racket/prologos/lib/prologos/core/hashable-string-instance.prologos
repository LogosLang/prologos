ns prologos::core::hashable-string-instance

require [prologos::core::hashable-trait :refer [Hashable]]

;; ========================================
;; Hashable String — use Racket's equal-hash-code
;; ========================================
;; equal-hash-code returns a fixnum; marshal as Nat for the hash trait.

foreign racket "racket/base" [equal-hash-code :as string-hash-nat : String -> Nat]

impl Hashable String
  defn hash [s : String] <Nat>
    string-hash-nat s
