ns prologos::core::neg-trait

;; ========================================
;; Neg Trait — unary negation
;; ========================================
;; Neg A = A -> A (single-method: dict IS the function)
;; No Nat instance (negation leaves Nat domain).

trait Neg {A}
  neg : A -> A
  :doc "Unary negation over type A"
  :laws
    - :name "involution"
      :forall {x : A}
      :holds [eq? [neg [neg x]] x]

;; Int instance
impl Neg Int
  defn neg [x : Int] <Int>
    int-neg x
