ns prologos.core.from-trait

;; ========================================
;; From Trait — lossless conversion from A to B
;; ========================================
;; From A B = A -> B (single-method: dict IS the function)
;; Generated: deftype From, accessor From-from
;; Instance key pattern: SourceType-TargetType--From
;; Example: Nat-Int--From--dict

trait From {A B}
  from : A -> B
