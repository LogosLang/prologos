ns prologos::core::sub-trait

require [prologos::data::nat :refer [sub]]

;; ========================================
;; Sub Trait — binary subtraction
;; ========================================
;; Sub A = A A -> A (single-method: dict IS the function)
;; Nat sub is saturating: sub(x, y) = max(x - y, 0)

trait Sub {A}
  sub : A A -> A
  :doc "Binary subtraction over type A"

;; Nat instance — saturating subtraction
impl Sub Nat
  defn sub [x y] <Nat>
    sub x y
